---
import CrmLayout from '../../../../layouts/CrmLayout.astro';
import Icon from '../../../../components/ui/Icon.vue';
import PropertyForm from '../../../../components/crm/PropertyForm.vue';
import { getPropertyById } from '../../../../services/properties';

const { id } = Astro.params;
const result = await getPropertyById(id!);
if (!result) return Astro.redirect('/crm/properties/');

const { properties: p } = result;
---

<CrmLayout title={`Edit ${p.address}`} active="properties">
  <section class="crm-frame space-y-6">
    <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--muted)]">
      <a href="/crm/properties/" class="hover:text-[var(--ink)]">Properties</a>
      <Icon name="chevron-right" size={14} />
      <a href={`/crm/properties/${p.id}/`} class="hover:text-[var(--ink)]">{p.address}</a>
      <Icon name="chevron-right" size={14} />
      <span class="font-medium text-[var(--ink)]">Edit</span>
    </div>
    <h1 class="font-display text-5xl leading-none md:text-[4.2rem]">Edit Property</h1>
  </section>
  <section class="crm-frame">
    <PropertyForm client:load property={p as any} />
  </section>
</CrmLayout>
