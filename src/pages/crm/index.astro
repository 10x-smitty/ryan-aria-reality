---
import CrmLayout from '../../layouts/CrmLayout.astro';
import MetricCard from '../../components/crm/MetricCard.astro';
import StatusBadge from '../../components/crm/StatusBadge.astro';
import ActionButton from '../../components/ui/ActionButton.astro';
import { getPropertyMetrics } from '../../services/properties';
import { getDealMetrics } from '../../services/deals';
import { getAllDeals } from '../../services/deals';

const [propMetrics, dealMetrics, recentDeals] = await Promise.all([
  getPropertyMetrics(),
  getDealMetrics(),
  getAllDeals(),
]);

const fmt = (n: number) =>
  n >= 1_000_000 ? `$${(n / 1_000_000).toFixed(1)}M` : n >= 1000 ? `$${(n / 1000).toFixed(0)}K` : `$${n}`;

const metrics = [
  { label: 'Total Properties', value: String(propMetrics.total), inverse: true },
  { label: 'Active Listings', value: String(propMetrics.active) },
  { label: 'Closed Revenue', value: fmt(dealMetrics.closedValue) },
  { label: 'Conversion Rate', value: `${dealMetrics.conversionRate}%` },
];

const recent = recentDeals.slice(0, 5);
---

<CrmLayout title="Business Overview" active="dashboard">
  <section class="crm-frame space-y-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-3">
        <h1 class="font-display text-5xl leading-none md:text-[4.2rem]">Business Overview</h1>
        <p class="text-sm text-[var(--muted)] md:text-base">Track your real estate performance and deal pipeline.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <ActionButton href="/crm/properties/new" label="Add Property" variant="solid" icon="plus" />
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {metrics.map((m) => <MetricCard {...m} />)}
    </div>
  </section>

  <section class="crm-frame space-y-6">
    <div class="flex items-center justify-between gap-4">
      <h2 class="font-display text-3xl">Recent Deals</h2>
      <a href="/crm/deals/" class="text-sm text-[var(--muted)] hover:text-[var(--ink)]">View All</a>
    </div>

    {recent.length === 0 ? (
      <div class="surface-card rounded-3xl px-8 py-12 text-center text-sm text-[var(--muted)]">
        No deals yet. <a href="/crm/deals/" class="underline hover:text-[var(--ink)]">Create your first deal →</a>
      </div>
    ) : (
      <div class="surface-card overflow-hidden">
        <div class="overflow-x-auto">
          <div class="min-w-[860px]">
            <div class="grid grid-cols-[1.6fr_1.2fr_1fr_1fr_1fr] gap-6 bg-[var(--page-alt)] px-6 py-4 text-sm font-medium text-[var(--ink)]">
              <div>Deal</div><div>Contact</div><div>Value</div><div>Stage</div><div>Created</div>
            </div>
            {recent.map((deal, i) => (
              <div
                class:list={[
                  'grid grid-cols-[1.6fr_1.2fr_1fr_1fr_1fr] items-center gap-6 px-6 py-4',
                  i < recent.length - 1 && 'border-b border-[var(--border)]',
                ]}
              >
                <div class="text-sm font-medium text-[var(--ink)]">{deal.title}</div>
                <div class="text-sm text-[var(--ink)]">{deal.contactName ?? '—'}</div>
                <div class="font-display text-2xl leading-none">
                  {deal.dealValue ? fmt(deal.dealValue) : '—'}
                </div>
                <div><StatusBadge label={deal.stage} tone="outline" /></div>
                <div class="text-sm text-[var(--muted)]">
                  {new Date(deal.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    )}
  </section>
</CrmLayout>
