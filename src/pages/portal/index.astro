---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getDb } from '../../lib/db/client';
import { deals, contacts } from '../../lib/db/schema';
import { eq } from 'drizzle-orm';
import { getMilestones } from '../../services/transaction-timeline';
import { getUnreadCount } from '../../services/messages';
import { getDocumentsByDeal } from '../../services/documents';

const user = Astro.locals.user!;
const db = getDb();

// Find the deal linked to this customer
const customerDeal = await db
  .select()
  .from(deals)
  .where(eq(deals.customerUserId, user.id))
  .limit(1)
  .then((r) => r[0] ?? null);

// Find linked contact by email for info
const linkedContact = customerDeal
  ? await db
      .select()
      .from(contacts)
      .where(eq(contacts.email, user.email))
      .limit(1)
      .then((r) => r[0] ?? null)
  : null;

const milestones = customerDeal ? await getMilestones(customerDeal.id, true) : [];
const completedCount = milestones.filter((m) => m.completedAt).length;
const unreadMessages = await getUnreadCount(user.id);
const documents = customerDeal ? await getDocumentsByDeal(customerDeal.id, true) : [];

const PROGRESS_STAGES = ['Showing', 'Offer', 'Under Contract', 'Closed'];
const ALL_STAGES = ['New Lead', 'Qualified', 'Showing', 'Offer', 'Under Contract', 'Closed'];
const currentStageIndex = customerDeal ? ALL_STAGES.indexOf(customerDeal.stage) : -1;

// Pre-compute stage states to avoid <= operator inside template
const stageItems = PROGRESS_STAGES.map((stage, i) => {
  const idx = ALL_STAGES.indexOf(stage);
  return {
    stage,
    stepNum: i + 1,
    done: idx <= currentStageIndex,
    active: idx === currentStageIndex,
  };
});
---

<PortalLayout title="My Dashboard" active="dashboard">
  <div class="space-y-8">
    <!-- Welcome -->
    <div>
      <h1 class="font-display text-4xl text-[var(--ink)]">
        Welcome back, {user.fullName?.split(' ')[0] ?? 'there'}
      </h1>
      <p class="mt-2 text-[var(--muted)]">
        {customerDeal ? `Tracking your transaction: ${customerDeal.title}` : 'Your portal is ready. Your agent will link a deal to your account soon.'}
      </p>
    </div>

    {unreadMessages > 0 && (
      <a
        href="/portal/messages"
        class="flex items-center gap-3 rounded-2xl border border-[var(--accent)]/30 bg-[var(--accent)]/10 px-5 py-4 text-sm font-medium text-[var(--accent-deep)] transition hover:bg-[var(--accent)]/20"
      >
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-[var(--accent-deep)] text-xs font-bold text-white">
          {unreadMessages}
        </span>
        You have {unreadMessages} unread message{unreadMessages !== 1 ? 's' : ''} → View messages
      </a>
    )}

    <!-- Stat cards -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="surface-card rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--muted)]">Transaction Stage</p>
        <p class="mt-2 font-display text-2xl text-[var(--ink)]">
          {customerDeal ? customerDeal.stage : '—'}
        </p>
      </div>
      <div class="surface-card rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--muted)]">Milestones</p>
        <p class="mt-2 font-display text-2xl text-[var(--ink)]">
          {milestones.length > 0 ? `${completedCount} / ${milestones.length}` : '—'}
        </p>
      </div>
      <div class="surface-card rounded-2xl p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--muted)]">Documents</p>
        <p class="mt-2 font-display text-2xl text-[var(--ink)]">{documents.length > 0 ? documents.length : '—'}</p>
      </div>
    </div>

    {customerDeal && (
      <div class="surface-card rounded-2xl p-6">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-[0.15em] text-[var(--muted)]">Transaction Progress</h2>
        <div class="flex items-center gap-0">
          {stageItems.map(({ stage, stepNum, done, active }) => (
            <div class="flex flex-1 flex-col items-center gap-2">
              <div class={[
                'flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold transition',
                done ? 'bg-[var(--accent-deep)] text-white' : 'bg-[var(--page-alt)] text-[var(--muted)]',
              ].join(' ')}>
                {done ? '✓' : stepNum}
              </div>
              <span class={['text-center text-xs leading-tight', active ? 'font-semibold text-[var(--ink)]' : 'text-[var(--muted)]'].join(' ')}>
                {stage}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    {milestones.length > 0 && (
      <div class="surface-card rounded-2xl p-6">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--muted)]">Transaction Timeline</h2>
          <a href={`/portal/transaction/${customerDeal!.id}`} class="text-xs font-medium text-[var(--accent-deep)] hover:underline">
            View all →
          </a>
        </div>
        <ul class="space-y-3">
          {milestones.slice(0, 5).map((m) => (
            <li class="flex items-start gap-3">
              <span class={[
                'mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full text-xs',
                m.completedAt ? 'bg-green-100 text-green-700' : 'bg-[var(--page-alt)] text-[var(--muted)]',
              ].join(' ')}>
                {m.completedAt ? '✓' : '○'}
              </span>
              <div>
                <p class={['text-sm', m.completedAt ? 'text-[var(--ink)]' : 'text-[var(--muted)]'].join(' ')}>
                  {m.milestone}
                </p>
                {m.completedAt && (
                  <p class="text-xs text-[var(--muted)]">
                    {new Date(m.completedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </p>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Quick links -->
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      {[
        { href: '/portal/favorites', label: 'Saved Homes', icon: '♡' },
        { href: '/portal/documents', label: 'Documents', icon: '📄' },
        { href: '/portal/messages', label: 'Messages', icon: '💬' },
        { href: customerDeal ? `/portal/transaction/${customerDeal.id}` : '/portal/', label: 'Timeline', icon: '📋' },
      ].map((item) => (
        <a
          href={item.href}
          class="surface-card flex flex-col items-center gap-2 rounded-2xl p-6 text-center transition hover:border-[var(--accent-deep)]/30"
        >
          <span class="text-2xl">{item.icon}</span>
          <span class="text-sm font-medium text-[var(--ink)]">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</PortalLayout>
