---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getDb } from '../../lib/db/client';
import { deals } from '../../lib/db/schema';
import { eq } from 'drizzle-orm';
import { getDocumentsByDeal } from '../../services/documents';

const user = Astro.locals.user!;
const db = getDb();

const customerDeal = await db
  .select()
  .from(deals)
  .where(eq(deals.customerUserId, user.id))
  .limit(1)
  .then((r) => r[0] ?? null);

const documents = customerDeal ? await getDocumentsByDeal(customerDeal.id, true) : [];
---

<PortalLayout title="Documents" active="documents">
  <div class="space-y-6">
    <div>
      <h1 class="font-display text-4xl text-[var(--ink)]">Documents</h1>
      <p class="mt-1 text-sm text-[var(--muted)]">
        {customerDeal ? `Documents shared for: ${customerDeal.title}` : 'No active transaction linked to your account.'}
      </p>
    </div>

    {documents.length === 0 ? (
      <div class="surface-card rounded-2xl p-12 text-center">
        <p class="text-4xl">📄</p>
        <p class="mt-3 font-medium text-[var(--ink)]">No documents yet</p>
        <p class="mt-1 text-sm text-[var(--muted)]">
          {customerDeal
            ? 'Your agent will share documents here as your transaction progresses.'
            : 'Documents will appear once your agent links a transaction to your account.'}
        </p>
      </div>
    ) : (
      <div class="space-y-3">
        {documents.map((doc) => (
          <div class="surface-card flex items-center justify-between rounded-2xl px-5 py-4">
            <div class="flex items-center gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--page-alt)] text-xl">
                📄
              </div>
              <div>
                <p class="font-medium text-[var(--ink)]">{doc.name}</p>
                <p class="text-xs text-[var(--muted)]">
                  {doc.uploaderName ? `Uploaded by ${doc.uploaderName} · ` : ''}
                  {new Date(doc.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </p>
              </div>
            </div>
            {doc.publicUrl && (
              <a
                href={doc.publicUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-xl border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--ink)] transition hover:bg-[var(--page-alt)]"
              >
                Download
              </a>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</PortalLayout>
