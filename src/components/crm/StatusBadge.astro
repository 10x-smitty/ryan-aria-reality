---
import type { BadgeTone } from '../../data/site';

interface Props {
  label: string;
  tone?: BadgeTone;
}

const { label, tone = 'outline' } = Astro.props;

const toneClasses = {
  dark: 'border-transparent bg-[var(--ink)] text-[var(--page)]',
  outline: 'border border-[var(--border)] bg-transparent text-[var(--ink)]',
  soft: 'border border-[var(--border)] bg-[var(--page-alt)] text-[var(--ink)]',
} satisfies Record<BadgeTone, string>;
---

<span class:list={['inline-flex items-center rounded-full px-3 py-1 text-xs font-medium', toneClasses[tone]]}>
  {label}
</span>
