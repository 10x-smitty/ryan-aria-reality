---
import type { SessionUser } from '../../lib/auth/session';

interface Props {
  active: 'dashboard' | 'favorites' | 'documents' | 'messages' | 'transaction';
  user: SessionUser | null;
}

const { active, user } = Astro.props;

const nav = [
  { label: 'Dashboard', href: '/portal/', key: 'dashboard' },
  { label: 'Favorites', href: '/portal/favorites', key: 'favorites' },
  { label: 'Documents', href: '/portal/documents', key: 'documents' },
  { label: 'Messages', href: '/portal/messages', key: 'messages' },
];
---

<header class="sticky top-0 z-40 border-b border-[var(--border)] bg-[var(--surface)]/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/portal/" class="flex items-center gap-3">
      <span class="font-display text-xl text-[var(--ink)]">Ryan Aria</span>
      <span class="rounded-full bg-[var(--accent)]/20 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-[var(--accent-deep)]">
        Client Portal
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class={[
            'rounded-lg px-4 py-2 text-sm font-medium transition',
            active === item.key
              ? 'bg-[var(--ink)] text-[var(--page)]'
              : 'text-[var(--muted)] hover:bg-[var(--page-alt)] hover:text-[var(--ink)]',
          ].join(' ')}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      {user && (
        <span class="hidden text-sm text-[var(--muted)] md:block">
          {user.fullName ?? user.email}
        </span>
      )}
      <form method="POST" action="/api/auth/signout">
        <button
          type="submit"
          class="rounded-lg border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--muted)] transition hover:border-[var(--ink)] hover:text-[var(--ink)]"
        >
          Sign Out
        </button>
      </form>
    </div>
  </div>
</header>
