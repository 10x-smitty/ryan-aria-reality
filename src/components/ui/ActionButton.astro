---
import type { ActionLink } from '../../data/site';
import Icon from './Icon.vue';

interface Props extends ActionLink {}

const { href, label, variant, icon } = Astro.props;

const variantClasses = {
  solid: 'border-transparent bg-[var(--accent)] text-black hover:bg-[var(--accent-deep)]',
  outline: 'border border-[var(--border)] bg-transparent text-[var(--ink)] hover:bg-[var(--page-alt)]',
  dark: 'border-transparent bg-[var(--ink)] text-[var(--page)] hover:bg-[var(--ink-soft)]',
} as const;
---

<a
  href={href}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-full px-4 py-2.5 text-sm font-medium shadow-none hover:-translate-y-0.5',
    variantClasses[variant],
  ]}
>
  {icon && <Icon name={icon} size={15} />}
  <span>{label}</span>
</a>
