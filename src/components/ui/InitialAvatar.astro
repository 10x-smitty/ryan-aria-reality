---
interface Props {
  initials: string;
  size?: number;
  inverse?: boolean;
}

const { initials, size = 40, inverse = true } = Astro.props;
---

<span
  class:list={[
    'inline-flex shrink-0 items-center justify-center rounded-full text-xs font-semibold',
    inverse ? 'bg-[var(--ink)] text-[var(--page)]' : 'bg-[var(--page-alt)] text-[var(--ink)] border border-[var(--border)]',
  ]}
  style={`width:${size}px;height:${size}px;`}
>
  {initials}
</span>
